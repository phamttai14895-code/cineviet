# Copy file này thành .env và điền giá trị thật. KHÔNG commit file .env.
# Các giá trị dưới đây chỉ là placeholder — thay bằng secret thật trong .env (local / server).

PORT=5000
JWT_SECRET=your_jwt_secret_min_32_chars_here
FRONTEND_URL=https://your-domain.com

# Lưu ý: Frontend (Vite) không đọc file .env của backend. Cần tạo file frontend/.env
# (xem frontend/.env.example) với VITE_API_URL, VITE_TURNSTILE_SITE_KEY nếu dùng.

# --- Cloudflare Turnstile (Captcha đăng nhập/đăng ký) - https://dash.cloudflare.com/ → Turnstile ---
# Secret key (backend). Site key đặt ở frontend/.env: VITE_TURNSTILE_SITE_KEY
TURNSTILE_SECRET=your_turnstile_secret

# --- Gửi email mã xác thực khi đăng ký (SMTP) ---
# Gmail: bật 2 bước xác minh, tạo Mật khẩu ứng dụng https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=your_email@gmail.com
SITE_NAME=CineViet

# --- Google OAuth (đăng nhập bằng Google) - https://console.cloud.google.com/ ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback



# --- AI (gợi ý phim, hỏi đáp, viết lại mô tả khi crawl) - chọn một hãng ---
# Hãng: openai (mặc định) hoặc gemini
AI_PROVIDER=gemini
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Google Gemini: https://aistudio.google.com/apikey (free tier có giới hạn RPM/RPD — xem https://aistudio.google.com/rate-limit)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
# Cache kết quả gợi ý/hỏi AI (phút) để tiết kiệm quota; mặc định 10
AI_CACHE_TTL_MINUTES=10
# Tắt AI viết lại mô tả khi crawl (khi hết quota): đặt ENABLE_AI_REWRITE_ON_CRAWL=0
ENABLE_AI_REWRITE_ON_CRAWL=1

# --- TMDB - cast/đạo diễn + ảnh khi crawl - https://www.themoviedb.org/settings/api ---
TMDB_API_KEY=your_tmdb_api_key

# --- OMDb (IMDb) - bổ sung khi TMDB thiếu - https://www.omdbapi.com/apikey.aspx ---
OMDB_API_KEY=

# CSRF: bật double-submit cookie. Đặt =1 để bật.
ENABLE_CSRF=1
